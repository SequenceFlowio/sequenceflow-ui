cat > .gitignore << 'EOF'
# dependencies
node_modules/

# next
.next/
out/
tsconfig.tsbuildinfo

# local env
.env
.env.local
.env.*.local

# uploads and generated runtime data
uploads/
*.pdf
*.doc
*.docx

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
EOF

data/*.jsonl
data/support-logs.jsonl
public/uploads/